<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mapa de Vida - Autoconocimiento Profundo</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        :root {
            --primary: #2c3e50; --accent: #d35400; --bg: #f4f7f6; --card: #ffffff;
            --text: #2c3e50; --green: #27ae60; --blue: #2980b9; --border: transparent;
        }
        [data-theme="high-contrast"] {
            --primary: #000000; --accent: #ffff00; --bg: #000000; --card: #000000;
            --text: #ffffff; --green: #00ff00; --blue: #00ffff; --border: 2px solid #ffffff;
        }
        body { font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 0; transition: 0.3s; }
        .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
        
        .container { max-width: 800px; margin: 0 auto; padding: 20px; }
        header { text-align: center; padding: 30px 0; border-bottom: 3px solid var(--accent); margin-bottom: 20px; }
        
        /* Controles Accesibles */
        .controls { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px; margin-bottom: 20px; background: var(--card); padding: 15px; border-radius: 12px; border: var(--border); }
        select, .btn-mode { padding: 10px; border-radius: 8px; border: 1px solid #ccc; background: var(--card); color: var(--text); font-size: 1rem; cursor: pointer; }

        /* Pentagrama */
        .visual-map { position: relative; width: 300px; height: 300px; margin: 40px auto; background: var(--card); border-radius: 50%; border: var(--border); }
        .star-svg { width: 100%; height: 100%; fill: none; stroke: #eee; stroke-width: 2; }
        [data-theme="high-contrast"] .star-svg { stroke: #555; }
        .node { position: absolute; width: 50px; height: 50px; background: var(--accent); color: #000; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; border: 2px solid #000; z-index: 10; font-size: 1.2rem; }
        .node-label { position: absolute; font-size: 0.75rem; font-weight: bold; text-transform: uppercase; width: 80px; text-align: center; color: var(--text); }

        /* Resultados */
        .results { display: none; margin-top: 30px; animation: fadeIn 0.5s ease; }
        .card { background: var(--card); padding: 20px; margin-bottom: 15px; border-radius: 10px; border-left: 6px solid var(--accent); border-top: var(--border); border-right: var(--border); border-bottom: var(--border); box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .card h3 { margin-top: 0; color: var(--accent); }
        
        .btn-main { width: 100%; background: var(--accent); color: #000; border: none; padding: 18px; border-radius: 12px; font-weight: bold; font-size: 1.2rem; cursor: pointer; margin-top: 20px; }
        .share-group { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 20px; }
        .btn-social { padding: 12px; border-radius: 8px; border: none; color: white; font-weight: bold; text-decoration: none; text-align: center; cursor: pointer; }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @media (max-width: 500px) { .visual-map { width: 250px; height: 250px; } }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1 id="ui-title">Mapa de Vida</h1>
        <p id="ui-subtitle">Tu brújula numérica para la evolución personal</p>
    </header>

    <nav class="controls" aria-label="Ajustes de usuario">
        <select id="langSelect" onchange="changeLang()">
            <option value="es">Español 🇪🇸</option>
            <option value="en">English 🇺🇸</option>
            <option value="pt">Português 🇧🇷</option>
        </select>
        <button class="btn-mode" onclick="toggleContrast()" id="ui-contrast">🌓 Alto Contraste</button>
    </nav>

    <main class="input-section">
        <div style="text-align:center;">
            <label for="birthDate" id="ui-date-label">Selecciona tu fecha de nacimiento:</label><br><br>
            <input type="date" id="birthDate" style="padding:12px; border-radius:8px; border:1px solid #ccc; width:80%; font-size:1.1rem;">
            <button class="btn-main" onclick="generateMap()" id="ui-btn-calc">🔮 Generar Mi Mapa</button>
        </div>
    </main>

    <div id="results" class="results">
        <div id="pdf-area">
            <h2 style="text-align:center;">Mapa Cuántico Personal</h2>
            
            <div class="visual-map" role="img" aria-label="Pentagrama de Vida">
                <svg class="star-svg" viewBox="0 0 200 200"><polygon points="100,10 125,190 10,70 190,70 75,190" /></svg>
                <div class="node" style="top:-15px; left:125px;" id="node-alma"></div>
                <div class="node-label" style="top:-35px; left:110px;" id="lbl-alma">Alma</div>

                <div class="node" style="top:180px; left:160px;" id="node-karma"></div>
                <div class="node-label" style="top:235px; left:145px;" id="lbl-karma">Karma</div>

                <div class="node" style="top:60px; left:-15px;" id="node-gift"></div>
                <div class="node-label" style="top:65px; left:-95px;" id="lbl-gift">Regalo</div>

                <div class="node" style="top:60px; right:-15px;" id="node-dest"></div>
                <div class="node-label" style="top:65px; right:-95px;" id="lbl-dest">Destino</div>

                <div class="node" style="top:180px; left:90px; background:var(--green); color:#fff;" id="node-miss"></div>
                <div class="node-label" style="top:235px; left:75px;" id="lbl-miss">Misión</div>
            </div>

            <div id="text-details"></div>
        </div>

        <div class="no-print">
            <button class="btn-main" style="background:var(--blue); color:white;" onclick="savePDF()">📄 Guardar como PDF</button>
            <div class="share-group">
                <button class="btn-social" style="background:#25d366" onclick="shareWA()">WhatsApp</button>
                <button class="btn-social" style="background:#3b5998" onclick="shareSocial()">Compartir</button>
            </div>
        </div>
    </div>
</div>

<script>
const DATA = {
    es: {
        title: "Mapa de Vida", subtitle: "Tu brújula numérica", date: "Fecha de nacimiento:", btn: "Generar Mi Mapa",
        alma: "Alma", karma: "Karma", gift: "Regalo", dest: "Destino", miss: "Misión", contrast: "Alto Contraste",
        arq: {
            1: { t: "El Líder Inconsciente", d: "Iniciador y protector.", m: "Liderar con benevolencia.", a: "Expresión corporal." },
            2: { t: "El Mediador", d: "Mente negativa protectora.", m: "Asociarse sin perderse.", a: "Escritura diaria." },
            3: { t: "El Artista", d: "Expansión y alegría.", m: "Confianza creativa.", a: "Canto o arte." },
            4: { t: "El Organizador", d: "Estructura y servicio.", m: "Poner el intelecto al servicio del bien.", a: "Respiración rítmica." },
            5: { t: "El Corporalista", d: "Disciplina y libertad.", m: "Ser ejemplo de vitalidad.", a: "Ejercicio intenso." },
            6: { t: "El Místico", d: "Intuición y verbo.", m: "Perdonar y decretar.", a: "Meditación." },
            7: { t: "El Líder Bondadoso", d: "Carisma e inspiración.", m: "Inspirar desde la paz.", a: "Silencio." },
            8: { t: "El Sanador", d: "Abundancia y salud.", m: "Canalizar recursos éticos.", a: "Sanación manual." },
            9: { t: "Maestro de Sí Mismo", d: "Amor incondicional.", m: "Cerrar ciclos con gratitud.", a: "Estudio profundo." },
            10: { t: "Líder Duro", d: "Coraje y resolución.", m: "Iluminar sin destruir.", a: "Meditación solar." },
            11: { t: "Maestro 11", d: "Faro espiritual.", m: "Despertar la conciencia.", a: "Meditación diaria." }
        }
    },
    en: {
        title: "Life Map", subtitle: "Your numerical compass", date: "Birth Date:", btn: "Generate My Map",
        alma: "Soul", karma: "Karma", gift: "Gift", dest: "Destiny", miss: "Mission", contrast: "High Contrast",
        arq: { 1: { t: "Unconscious Leader", d: "Initiator & Protector.", m: "Lead with kindness.", a: "Body expression." } }
    }
};

let currentLang = 'es';

function changeLang() {
    currentLang = document.getElementById('langSelect').value;
    const l = DATA[currentLang];
    document.getElementById('ui-title').innerText = l.title;
    document.getElementById('ui-subtitle').innerText = l.subtitle;
    document.getElementById('ui-date-label').innerText = l.date;
    document.getElementById('ui-btn-calc').innerText = l.btn;
    document.getElementById('lbl-alma').innerText = l.alma;
    document.getElementById('lbl-karma').innerText = l.karma;
    document.getElementById('lbl-gift').innerText = l.gift;
    document.getElementById('lbl-dest').innerText = l.dest;
    document.getElementById('lbl-miss').innerText = l.miss;
    document.getElementById('ui-contrast').innerText = l.contrast;
}

function toggleContrast() {
    document.body.dataset.theme = document.body.dataset.theme === 'high-contrast' ? '' : 'high-contrast';
}

function reduce(n) {
    if ([11, 22, 33].includes(n)) return n;
    while (n > 11) {
        n = String(n).split('').reduce((a, b) => a + parseInt(b), 0);
        if ([11, 22, 33].includes(n)) return n;
    }
    if (n > 10 && n !== 11) n = String(n).split('').reduce((a, b) => a + parseInt(b), 0);
    return n;
}

function generateMap() {
    const input = document.getElementById('birthDate').value;
    if (!input) return;
    const [y, m, d] = input.split('-').map(Number);
    const sumY = y.toString().split('').reduce((a, b) => a + parseInt(b), 0);
    
    const alma = reduce(d);
    const karma = reduce(m);
    const gift = reduce(parseInt(y.toString().slice(-2)));
    const dest = reduce(sumY);
    const miss = reduce(alma + karma + dest);

    document.getElementById('node-alma').innerText = alma;
    document.getElementById('node-karma').innerText = karma;
    document.getElementById('node-gift').innerText = gift;
    document.getElementById('node-dest').innerText = dest;
    document.getElementById('node-miss').innerText = miss;

    const summary = [
        { l: DATA[currentLang].alma, v: alma },
        { l: DATA[currentLang].karma, v: karma },
        { l: DATA[currentLang].gift, v: gift },
        { l: DATA[currentLang].dest, v: dest },
        { l: DATA[currentLang].miss, v: miss }
    ];

    let html = "";
    summary.forEach(item => {
        const arq = DATA[currentLang].arq[item.v] || { t: "Número Maestro", d: "Alta frecuencia.", m: "Servicio universal.", a: "Paz." };
        html += `<div class="card"><h3>${item.l}: ${arq.t} (${item.v})</h3><p><strong>Esencia:</strong> ${arq.d}</p><p><strong>🎯 Misión:</strong> ${arq.m}</p><p><strong>✨ Activación:</strong> ${arq.a}</p></div>`;
    });

    document.getElementById('text-details').innerHTML = html;
    document.getElementById('results').style.display = 'block';
}

function savePDF() {
    const element = document.getElementById('pdf-area');
    html2pdf().from(element).set({ margin: 1, filename: 'Mapa_De_Vida_Reporte.pdf' }).save();
}

function shareWA() {
    const url = window.location.href;
    const text = encodeURIComponent(`¡Mira mi Mapa de Vida! Descubre tu misión aquí: ${url}`);
    window.open(`https://wa.me/?text=${text}`, '_blank');
}

function shareSocial() {
    if (navigator.share) {
        navigator.share({ title: 'Mapa de Vida', text: 'Descubre tu propósito con este análisis numerológico.', url: window.location.href });
    }
}
</script>
</body>
</html>
